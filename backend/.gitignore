/storage/firebase-credentials.json
/storage/certs/*.pem
/storage/*.json
/storage/*.key
/storage/*.cert
/storage/*.p12
*.json
!composer.json
!package.json
!package-lock.json
!composer.lock
!phpunit.xml
!pint.json

