APP_NAME=ShopDee
APP_URL=https://api.shopdee.io.vn
APP_ENV=local
APP_KEY=
APP_DEBUG=true

FRONTEND_URL=https://shopdee.io.vn
SESSION_DOMAIN=.shopdee.io.vn
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# ==========================================
# CẤU HÌNH DOMAIN & TUNNEL
# ==========================================
CLOUDFLARE_TUNNEL_URL=https://api.shopdee.io.vn
SANCTUM_STATEFUL_DOMAINS=shopdee.io.vn,api.shopdee.io.vn

# ==========================================
# CẤU HÌNH DATABASE (XAMPP / MySQL)
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shopdee
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# CẤU HÌNH PUSHER (Chat Realtime)
# ==========================================
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# ==========================================
# CẤU HÌNH CLOUDINARY
# ==========================================
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# CẤU HÌNH GOOGLE LOGIN
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://api.shopdee.io.vn/api/auth/google/callback

# ==========================================
# CẤU HÌNH MAIL (Gmail SMTP)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# CẤU HÌNH AI SERVICE
# ==========================================
AI_API_URL=http://localhost:5000