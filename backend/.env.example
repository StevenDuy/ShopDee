APP_NAME=ShopDee
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# ==========================================
# CẤU HÌNH DATABASE (XAMPP / MySQL)
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shopdee
DB_USERNAME=root
DB_PASSWORD=

# Nếu dùng TiDB Cloud (Cơ sở dữ liệu đám mây), hãy uncomment các dòng dưới:
# DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# MYSQL_ATTR_SSL_CA=storage/certs/isrgrootx1.pem

# ==========================================
# CẤU HÌNH PUSHER (Chat Realtime)
# ==========================================
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID="NHẬP_ID_CỦA_BẠN"
PUSHER_APP_KEY="NHẬP_KEY_CỦA_BẠN"
PUSHER_APP_SECRET="NHẬP_SECRET_CỦA_BẠN"
PUSHER_APP_CLUSTER="ap1"

# ==========================================
# CẤU HÌNH CLOUDINARY (Nén & Lưu trữ ảnh)
# ==========================================
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# CẤU HÌNH FIREBASE (Dữ liệu bổ trợ)
# ==========================================
FIREBASE_CREDENTIALS="storage/firebase-credentials.json"
FIREBASE_DATABASE_URL="https://your-project-id.firebaseio.com"

# ==========================================
# CẤU HÌNH GOOGLE LOGIN
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ==========================================
# CẤU HÌNH MAIL (Gmail SMTP)
# ==========================================
# Bước 1: Bật 2FA trên Google
# Bước 2: Tạo App Password tại: https://myaccount.google.com/apppasswords
# Bước 3: Điền thông tin vào các biến dưới đây
# 6. "http://localhost:8000/api/auth/google/callback" nhớ bỏ vài redirec url

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_16_chars
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="your_email@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"