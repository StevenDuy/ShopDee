# ==========================================
# CẤU HÌNH API URL
# ==========================================
# Link tới Backend Laravel (Cổng mặc định là 8000)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ==========================================
# CẤU HÌNH PUSHER (Chat Realtime)
# ==========================================
# Lưu ý: Các biến này bắt buộc phải có tiền tố NEXT_PUBLIC_
NEXT_PUBLIC_PUSHER_APP_KEY="CO_PY_TU_TRANG_CHU_PUSHER"
NEXT_PUBLIC_PUSHER_APP_CLUSTER="ap1"

# ==========================================
# CẤU HÌNH FIREBASE (AI & Analytics)
# ==========================================
# Thông tin lấy từ Firebase Console -> Project Settings -> Web App
NEXT_PUBLIC_FIREBASE_API_KEY="AI_KEY_CUA_BAN"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="1:XXXX:web:YYYY"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-ZZZZ"

# ==========================================
# CẤU HÌNH GOOGLE LOGIN
# ==========================================
# ID dùng để hiện nút đăng nhập Google ở Frontend
NEXT_PUBLIC_GOOGLE_CLIENT_ID="SAO_CHEP_TU_GOOGLE_CLOUD_CONSOLE"
